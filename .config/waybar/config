{
  "layer": "bottom",
  "position": "top",
  "height": 24,
  "spacing": 5,
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["clock#date", "clock#time"],
  "modules-right": [
    "idle_inhibitor",
    "custom/spotify",
    "battery",
    "pulseaudio",
    "tray",

  ],
  "clock#time": {
    "format": "{:%H:%M}",
    "interval": 1
  },
  "clock#date": {
    "format": "{:%d/%m/%Y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "interval": 360,
    "calendar": {
      "mode": "month",
      "mode-mon-col": 4,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#c0caf5'><b>{}</b></span>",
        "days": "<span color='#c0caf5'><b>{}</b></span>",
        "weeks": "<span color='#7dcfff'><b>W{}</b></span>",
        "weekdays": "<span color='#ff9e64'><b>{}</b></span>",
        "today": "<span color='#f7768e'><b><u>{}</u></b></span>"
      }
    }
  },
  "battery": {
    "interval": 10,
    "format": "{icon} {capacity}%",
    "format-plugged": "plugged",
    "format-charging": "{icon} {capacity}% ",
    "format-charged": "{icon} {capacity}% ",
    "format-full": "{icon} {capacity}% ",
    "format-icons": {
      "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°¢‌", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
      "discharging": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚"],
      "plugged": "ï‡¦"
    },
    "tooltip": true
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}",
    "format-icons": {
      "default": ["َ°‌ں", "َ°•؟", "َ°–€", "َ°•¾"]
    },
    "tooltip-format": "Volume: {volume}\n{desc}",
    "interval": 1,
    "tooltip": true,
    "on-click": "~/.config/sway/scripts/togglePavucontrol.sh"
  },
  "tray": {
    "show-passive-items": true,
    "spacing": 5,
    "icon-size": 14
  },
  "custom/spotify": {
    "exec": "/usr/bin/python3 ~/.config/waybar/modules/mediaplayer.py --player spotify",
    "format": "ï†¼  {}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": " {icon} ",
    "format-icons": {
      "activated": "َ°ˆˆ",
      "deactivated": "َ°ˆ‰"
    },
    "tooltip-format": "Idle inhibitor is {state}"
  },
  "network": {
    "format": "{icon}",
    "format-icons": {
      "wifi": "َ°–©",
      "ethernet": "َ°ˆ€",
      "disconnected": "َ±ڑµ",
      "disabled": "َ°–ھ"
    },
    "tooltip-format-wifi": "ESSID: {essid}\nSignal strength: {signalStrength}%\nIP: {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}/{cidr}",
    "interval": 5,
    "on-click": "nm-applet"
  },
  "bluetooth": {
    "format": "{icon}",
    "format-icons": {
      "connected": "َ°‚±",
      "disconnected": "َ°‚²",
      "disabled": "َ°‚²",
      "enabled": "ïٹ”"
    },
    "tooltip": true,
    "on-click": "~/.config/sway/scripts/toggleBlueman.sh"
  },
 }
}
