{
  "layer": "bottom",
  "position": "top",
  "height": 24,
  "spacing": 5,
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["custom/spotify"],
  "modules-right": ["tray", "battery", "pulseaudio", "clock"],

  "clock": {
    "format": "{:%d %b %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "interval": 1,
    "calendar": {
      "mode": "month",
      "mode-mon-col": 4,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#c0caf5'><b>{}</b></span>",
        "days": "<span color='#c0caf5'><b>{}</b></span>",
        "weeks": "<span color='#7dcfff'><b>W{}</b></span>",
        "weekdays": "<span color='#ff9e64'><b>{}</b></span>",
        "today": "<span color='#f7768e'><b><u>{}</u></b></span>"
      }
    }
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ²³"],
    "format-time": "{H}h{M}m",
    "format-charging": "{icon} {capacity}% - {time}",
    "format-charging-icons": ["σΑΔ€", "σΑ²Ü", "σΑ²΅", "σΑ²à", "σΑΔù", "σΑΔù", "σΑΔû", "σΑ²ä", "σΑ²΄", "σΑ²Ö"],
    "format-full": "{icon}",
    "interval": 10,
    "tooltip": false,
    "on-click": "2"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-icons": {
      "default": ["σΑùü", "σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "tooltip-format": "Volume: {volume}\n{desc}",
    "interval": 1,
    "tooltip": true,
    "on-click": "~/.config/sway/scripts/togglePavucontrol.sh"
  },
  "tray": {
    "show-passive-items": true,
    "spacing": 8,
    "icon-size": 14
  },
  "custom/spotify": {
    "exec": "/usr/bin/python3 ~/.config/waybar/modules/mediaplayer.py --player spotify",
    "format": "οÜΦ  {}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "σΑΨΣ",
      "deactivated": "σΑÖΕ"
    },
    "tooltip": true,
    "tooltip-format": "Caffeine is {!state}"
  },

  "network": {
    "format": "{icon}",
    "format-icons": {
      "wifi": "σΑ•©",
      "ethernet": "σΑàÄ",
      "disconnected": "σ±öΒ",
      "disabled": "σΑ•Σ"
    },
    "tooltip-format-wifi": "ESSID: {essid}\nSignal strength: {signalStrength}%\nIP: {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}/{cidr}",
    "interval": 5,
    "on-click": "nm-applet"
  },
  "bluetooth": {
    "format": "{icon}",
    "format-icons": {
      "connected": "σΑ²±",
      "disconnected": "σΑ²≤",
      "disabled": "σΑ²≤",
      "enabled": "οäî"
    },
    "tooltip": true,
    "on-click": "~/.config/sway/scripts/toggleBlueman.sh"
  }
}
